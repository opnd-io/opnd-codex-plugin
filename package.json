{
  "name": "@opnd-io/opnd-codex-plugin",
  "version": "2.2.1",
  "private": true,
  "type": "module",
  "description": "Use Codex from Claude Code to review code or delegate tasks.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "bump-version": "node scripts/bump-version.mjs",
    "check-version": "node scripts/bump-version.mjs --check",
    "prebuild": "node -e \"require('node:fs').mkdirSync('plugins/opnd-codex/.generated/app-server-types',{recursive:true})\" && codex app-server generate-ts --out plugins/opnd-codex/.generated/app-server-types",
    "build": "tsc -p tsconfig.app-server.json",
    "efficiency-report": "node plugins/opnd-codex/scripts/codex-efficiency-report.mjs",
    "test": "node --test tests/*.test.mjs tests/daily-evolve/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
